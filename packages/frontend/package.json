{
  "name": "@symphony/frontend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "dependencies": {
    "@tanstack/react-query": "^5.90.5",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.9.4"
  },
  "scripts": {
    "build": "pnpm run build:react",
    "build:vanilla": "vite build --config ../../frontend/vite.config.ts",
    "build:react": "vite build --config ./vite.config.ts",
    "dev": "pnpm run dev:react",
    "dev:vanilla": "vite --config ../../frontend/vite.config.ts",
    "dev:react": "vite --config ./vite.config.ts",
    "generate:openapi-types": "tsx ./scripts/generate-openapi-types.ts",
    "typecheck:react": "tsc --noEmit -p ./tsconfig.json",
    "typecheck:vanilla": "tsc --noEmit -p ../../frontend/tsconfig.json"
  },
  "devDependencies": {
    "openapi-typescript": "^7.10.1"
  }
}
