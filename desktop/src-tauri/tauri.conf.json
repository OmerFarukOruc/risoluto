{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Symphony Desktop",
  "version": "0.1.0",
  "identifier": "com.symphony.orchestrator.desktop",
  "build": {
    "beforeBuildCommand": "",
    "beforeDevCommand": "",
    "frontendDist": "../web"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": null
    },
    "windows": [
      {
        "title": "Symphony Desktop",
        "width": 1280,
        "height": 840,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}
