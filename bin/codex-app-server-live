#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd "$(dirname "$0")/.." && pwd)"
fixture_home="$repo_root/tests/fixtures/codex-home-custom-provider"
runtime_home="$repo_root/.symphony-codex-home"
source_auth_home="${CODEX_AUTH_SOURCE_HOME:-$HOME/.codex}"

mkdir -p "$runtime_home"

cp "$fixture_home/config.toml" "$runtime_home/config.toml"

if [ -d "$fixture_home/skills" ] && [ ! -d "$runtime_home/skills" ]; then
  cp -R "$fixture_home/skills" "$runtime_home/skills"
fi

if [ ! -f "$source_auth_home/auth.json" ]; then
  echo "missing auth.json in $source_auth_home; cannot launch codex app-server against CLIProxyAPI" >&2
  exit 1
fi

cp "$source_auth_home/auth.json" "$runtime_home/auth.json"

openai_api_key="$(
  SOURCE_AUTH_HOME="$source_auth_home" python - <<'PY'
import json
import os
from pathlib import Path

auth = json.loads(Path(os.environ["SOURCE_AUTH_HOME"]).joinpath("auth.json").read_text())
value = auth.get("OPENAI_API_KEY", "")
if not isinstance(value, str):
    value = ""
print(value, end="")
PY
)"

if [ -z "$openai_api_key" ]; then
  echo "OPENAI_API_KEY is missing in $source_auth_home/auth.json; cannot authenticate to CLIProxyAPI" >&2
  exit 1
fi

exec env CODEX_HOME="$runtime_home" OPENAI_API_KEY="$openai_api_key" codex app-server "$@"
