{
  "openapi": "3.1.0",
  "info": {
    "title": "Risoluto API",
    "version": "0.4.0",
    "description": "REST API for Risoluto — manages issues, workspaces, config, and agent lifecycle."
  },
  "servers": [
    {
      "url": "http://localhost:4000",
      "description": "Local Risoluto instance"
    }
  ],
  "paths": {
    "/api/v1/state": {
      "get": {
        "tags": ["State & Metrics"],
        "summary": "Get runtime state snapshot",
        "operationId": "getState",
        "responses": {
          "200": {
            "description": "Current runtime snapshot",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/runtime": {
      "get": {
        "tags": ["State & Metrics"],
        "summary": "Get runtime metadata",
        "operationId": "getRuntime",
        "responses": {
          "200": {
            "description": "Runtime information",
            "content": {
              "application/json": {
                "schema": {
                  "$schema": "https://json-schema.org/draft/2020-12/schema",
                  "type": "object",
                  "properties": {
                    "version": {
                      "type": "string"
                    },
                    "data_dir": {
                      "type": "string"
                    },
                    "feature_flags": {
                      "type": "object",
                      "propertyNames": {
                        "type": "string"
                      },
                      "additionalProperties": {}
                    },
                    "provider_summary": {
                      "type": "string"
                    }
                  },
                  "required": ["version", "data_dir", "feature_flags", "provider_summary"],
                  "additionalProperties": false
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/refresh": {
      "post": {
        "tags": ["State & Metrics"],
        "summary": "Request a tracker refresh",
        "operationId": "postRefresh",
        "responses": {
          "202": {
            "description": "Refresh queued",
            "content": {
              "application/json": {
                "schema": {
                  "$schema": "https://json-schema.org/draft/2020-12/schema",
                  "type": "object",
                  "properties": {
                    "queued": {
                      "type": "boolean"
                    },
                    "coalesced": {
                      "type": "boolean"
                    },
                    "requested_at": {
                      "type": "string"
                    }
                  },
                  "required": ["queued", "coalesced", "requested_at"],
                  "additionalProperties": false
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/transitions": {
      "get": {
        "tags": ["State & Metrics"],
        "summary": "Get available state transitions",
        "operationId": "getTransitions",
        "responses": {
          "200": {
            "description": "Transitions list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          }
        }
      }
    },
    "/metrics": {
      "get": {
        "tags": ["State & Metrics"],
        "summary": "Prometheus-style metrics",
        "operationId": "getMetrics",
        "responses": {
          "200": {
            "description": "Plain-text metrics",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/{issue_identifier}": {
      "get": {
        "tags": ["Issues"],
        "summary": "Get issue detail",
        "operationId": "getIssueDetail",
        "parameters": [
          {
            "name": "issue_identifier",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Issue identifier (e.g. ENG-123)"
          }
        ],
        "responses": {
          "200": {
            "description": "Issue detail",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "404": {
            "description": "Issue not found",
            "content": {
              "application/json": {
                "schema": {
                  "$schema": "https://json-schema.org/draft/2020-12/schema",
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "object",
                      "properties": {
                        "code": {
                          "type": "string"
                        },
                        "message": {
                          "type": "string"
                        }
                      },
                      "required": ["code", "message"],
                      "additionalProperties": false
                    }
                  },
                  "required": ["error"],
                  "additionalProperties": false
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/{issue_identifier}/abort": {
      "post": {
        "tags": ["Issues"],
        "summary": "Abort a running issue",
        "operationId": "abortIssue",
        "parameters": [
          {
            "name": "issue_identifier",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Issue identifier (e.g. ENG-123)"
          }
        ],
        "responses": {
          "200": {
            "description": "Already stopping",
            "content": {
              "application/json": {
                "schema": {
                  "$schema": "https://json-schema.org/draft/2020-12/schema",
                  "type": "object",
                  "properties": {
                    "ok": {
                      "type": "boolean",
                      "const": true
                    },
                    "status": {
                      "type": "string",
                      "const": "stopping"
                    },
                    "already_stopping": {
                      "type": "boolean"
                    },
                    "requested_at": {
                      "type": "string"
                    }
                  },
                  "required": ["ok", "status", "already_stopping", "requested_at"],
                  "additionalProperties": false
                }
              }
            }
          },
          "202": {
            "description": "Abort accepted",
            "content": {
              "application/json": {
                "schema": {
                  "$schema": "https://json-schema.org/draft/2020-12/schema",
                  "type": "object",
                  "properties": {
                    "ok": {
                      "type": "boolean",
                      "const": true
                    },
                    "status": {
                      "type": "string",
                      "const": "stopping"
                    },
                    "already_stopping": {
                      "type": "boolean"
                    },
                    "requested_at": {
                      "type": "string"
                    }
                  },
                  "required": ["ok", "status", "already_stopping", "requested_at"],
                  "additionalProperties": false
                }
              }
            }
          },
          "404": {
            "description": "Issue not found",
            "content": {
              "application/json": {
                "schema": {
                  "$schema": "https://json-schema.org/draft/2020-12/schema",
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "object",
                      "properties": {
                        "code": {
                          "type": "string"
                        },
                        "message": {
                          "type": "string"
                        }
                      },
                      "required": ["code", "message"],
                      "additionalProperties": false
                    }
                  },
                  "required": ["error"],
                  "additionalProperties": false
                }
              }
            }
          },
          "409": {
            "description": "Conflict",
            "content": {
              "application/json": {
                "schema": {
                  "$schema": "https://json-schema.org/draft/2020-12/schema",
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "object",
                      "properties": {
                        "code": {
                          "type": "string"
                        },
                        "message": {
                          "type": "string"
                        }
                      },
                      "required": ["code", "message"],
                      "additionalProperties": false
                    }
                  },
                  "required": ["error"],
                  "additionalProperties": false
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/{issue_identifier}/model": {
      "post": {
        "tags": ["Issues"],
        "summary": "Update model override for an issue",
        "operationId": "updateModel",
        "parameters": [
          {
            "name": "issue_identifier",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Issue identifier (e.g. ENG-123)"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$schema": "https://json-schema.org/draft/2020-12/schema",
                "type": "object",
                "properties": {
                  "model": {
                    "type": "string",
                    "minLength": 1
                  },
                  "reasoning_effort": {
                    "anyOf": [
                      {
                        "type": "string",
                        "enum": ["none", "minimal", "low", "medium", "high", "xhigh"]
                      },
                      {
                        "type": "null"
                      }
                    ]
                  },
                  "reasoningEffort": {
                    "anyOf": [
                      {
                        "type": "string",
                        "enum": ["none", "minimal", "low", "medium", "high", "xhigh"]
                      },
                      {
                        "type": "null"
                      }
                    ]
                  }
                },
                "required": ["model"],
                "additionalProperties": false
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Model updated",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": {
                  "$schema": "https://json-schema.org/draft/2020-12/schema",
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string",
                      "const": "validation_error"
                    },
                    "details": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "code": {
                            "type": "string"
                          },
                          "path": {
                            "type": "array",
                            "items": {
                              "anyOf": [
                                {
                                  "type": "string"
                                },
                                {
                                  "type": "number"
                                }
                              ]
                            }
                          },
                          "message": {
                            "type": "string"
                          }
                        },
                        "required": ["code", "path", "message"],
                        "additionalProperties": false
                      }
                    }
                  },
                  "required": ["error", "details"],
                  "additionalProperties": false
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/{issue_identifier}/transition": {
      "post": {
        "tags": ["Issues"],
        "summary": "Transition an issue to a new state",
        "operationId": "transitionIssue",
        "parameters": [
          {
            "name": "issue_identifier",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Issue identifier (e.g. ENG-123)"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$schema": "https://json-schema.org/draft/2020-12/schema",
                "type": "object",
                "properties": {
                  "target_state": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "required": ["target_state"],
                "additionalProperties": false
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Transition applied",
            "content": {
              "application/json": {
                "schema": {
                  "$schema": "https://json-schema.org/draft/2020-12/schema",
                  "type": "object",
                  "properties": {
                    "ok": {
                      "type": "boolean"
                    },
                    "from": {
                      "type": "string"
                    },
                    "to": {
                      "type": "string"
                    },
                    "reason": {
                      "type": "string"
                    }
                  },
                  "required": ["ok"],
                  "additionalProperties": false
                }
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": {
                  "$schema": "https://json-schema.org/draft/2020-12/schema",
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string",
                      "const": "validation_error"
                    },
                    "details": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "code": {
                            "type": "string"
                          },
                          "path": {
                            "type": "array",
                            "items": {
                              "anyOf": [
                                {
                                  "type": "string"
                                },
                                {
                                  "type": "number"
                                }
                              ]
                            }
                          },
                          "message": {
                            "type": "string"
                          }
                        },
                        "required": ["code", "path", "message"],
                        "additionalProperties": false
                      }
                    }
                  },
                  "required": ["error", "details"],
                  "additionalProperties": false
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/{issue_identifier}/attempts": {
      "get": {
        "tags": ["Attempts"],
        "summary": "List attempts for an issue",
        "operationId": "listAttempts",
        "parameters": [
          {
            "name": "issue_identifier",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Issue identifier (e.g. ENG-123)"
          }
        ],
        "responses": {
          "200": {
            "description": "Attempts list",
            "content": {
              "application/json": {
                "schema": {
                  "$schema": "https://json-schema.org/draft/2020-12/schema",
                  "type": "object",
                  "properties": {
                    "attempts": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "propertyNames": {
                          "type": "string"
                        },
                        "additionalProperties": {}
                      }
                    },
                    "current_attempt_id": {
                      "anyOf": [
                        {
                          "type": "string"
                        },
                        {
                          "type": "null"
                        }
                      ]
                    }
                  },
                  "required": ["attempts", "current_attempt_id"],
                  "additionalProperties": false
                }
              }
            }
          },
          "404": {
            "description": "Issue not found",
            "content": {
              "application/json": {
                "schema": {
                  "$schema": "https://json-schema.org/draft/2020-12/schema",
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "object",
                      "properties": {
                        "code": {
                          "type": "string"
                        },
                        "message": {
                          "type": "string"
                        }
                      },
                      "required": ["code", "message"],
                      "additionalProperties": false
                    }
                  },
                  "required": ["error"],
                  "additionalProperties": false
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/attempts/{attempt_id}": {
      "get": {
        "tags": ["Attempts"],
        "summary": "Get attempt detail",
        "operationId": "getAttemptDetail",
        "parameters": [
          {
            "name": "attempt_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
