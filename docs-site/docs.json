{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "Risoluto",
  "colors": {
    "primary": "#9a472b",
    "light": "#c96e4a",
    "dark": "#9a472b"
  },
  "background": {
    "color": {
      "light": "#f7f5f1",
      "dark": "#0c1016"
    }
  },
  "logo": {
    "dark": "/logo/dark.svg",
    "light": "/logo/light.svg",
    "href": "https://risolu.to"
  },
  "favicon": "/favicon.svg",
  "navbar": {
    "links": [
      {
        "type": "github",
        "href": "https://github.com/OmerFarukOruc/risoluto"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://risolu.to"
    }
  },
  "banner": {
    "content": "Risoluto is in pre-launch beta — public availability targeted for May 2026. [Read the introduction](/introduction) or [star us on GitHub](https://github.com/OmerFarukOruc/risoluto) to follow along.",
    "dismissible": true
  },
  "contextual": {
    "options": ["copy", "view", "assistant", "chatgpt", "claude", "perplexity", "grok", "aistudio", "devin", "windsurf"]
  },
  "search": {
    "prompt": "Search Risoluto docs..."
  },
  "metadata": {
    "timestamp": true
  },
  "api": {
    "openapi": "openapi.json",
    "playground": {
      "display": "interactive"
    },
    "examples": {
      "languages": ["bash", "javascript", "python"],
      "defaults": "all"
    },
    "mdx": {
      "server": "http://127.0.0.1:4000",
      "auth": {
        "method": "bearer"
      }
    }
  },
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "Changelog",
          "icon": "clock-rotate-left",
          "href": "/changelog"
        }
      ]
    },
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get Started",
            "pages": ["introduction", "quickstart", "faq"]
          },
          {
            "group": "Core Concepts",
            "pages": ["concepts/how-it-works", "concepts/runtime", "concepts/trust-model"]
          },
          {
            "group": "Guides",
            "pages": [
              "guides/setup-wizard",
              "guides/docker",
              "guides/configuration",
              "guides/dashboard",
              "guides/notifications",
              "guides/security"
            ]
          },
          {
            "group": "Recipes",
            "icon": "flask",
            "pages": ["recipes/multi-repo", "recipes/custom-sandbox", "recipes/monitoring-stack"]
          },
          {
            "group": "Operating",
            "pages": ["operating/observability", "operating/troubleshooting"]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Overview",
            "pages": ["api-reference/overview"]
          },
          {
            "group": "All Endpoints",
            "pages": ["api-reference/endpoints"]
          }
        ]
      }
    ]
  },
  "footer": {
    "brand": "*con risoluto*",
    "socials": {
      "github": "https://github.com/OmerFarukOruc/risoluto",
      "website": "https://risolu.to"
    },
    "links": [
      {
        "header": "Docs",
        "items": [
          { "label": "Quickstart", "href": "/quickstart" },
          { "label": "Configuration", "href": "/guides/configuration" },
          { "label": "API Reference", "href": "/api-reference/overview" },
          { "label": "Changelog", "href": "/changelog" }
        ]
      },
      {
        "header": "Resources",
        "items": [
          { "label": "GitHub", "href": "https://github.com/OmerFarukOruc/risoluto" },
          { "label": "Issues", "href": "https://github.com/OmerFarukOruc/risoluto/issues" },
          { "label": "Releases", "href": "https://github.com/OmerFarukOruc/risoluto/releases" }
        ]
      }
    ]
  },
  "redirects": [
    { "source": "/symphony", "destination": "/" },
    { "source": "/symphony/:path*", "destination": "/" },
    { "source": "/docs", "destination": "/" },
    { "source": "/docs/:path*", "destination": "/:path*" },
    { "source": "/api", "destination": "/api-reference/overview" },
    { "source": "/api/:path*", "destination": "/api-reference/endpoints" }
  ],
  "seo": {
    "indexing": "all",
    "metatags": {
      "canonical": "https://docs.risolu.to",
      "og:site_name": "Risoluto",
      "og:type": "website",
      "og:url": "https://docs.risolu.to",
      "og:image": "/images/og-image.png",
      "og:locale": "en_US",
      "twitter:card": "summary_large_image",
      "twitter:image": "/images/og-image.png",
      "description": "Risoluto turns your issue tracker into an autonomous coding pipeline. Local orchestration engine that dispatches sandboxed AI agents to close Linear issues automatically.",
      "keywords": "AI coding agent, autonomous coding, Linear integration, issue automation, code generation, AI orchestration, developer tools"
    }
  },
  "integrations": {
    "posthog": {
      "apiKey": "phc_syRRQjw8q6HqFgTPnqwFEMKqJeeJBjLzmX8ysNfmVgyD",
      "apiHost": "https://t.risolu.to"
    }
  }
}
